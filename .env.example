# Lean-LangChain — environment template
# Copy to .env and set values. Never commit .env. See docs/running.md.

# --- Gateway & CLI ---
OBR_GATEWAY_URL=http://localhost:8000

# --- Review UI (Next.js); set in apps/review-ui/.env.local or shell ---
# NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# --- State (production: use Postgres) ---
# REVIEW_STORE=memory
# CHECKPOINTER=memory
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Lean / acceptance lane ---
# OBR_USE_REAL_LEAN=
# OBR_USE_LEAN_LSP=
# OBR_USE_REAL_AXIOM_AUDIT=
# OBR_AXIOM_AUDIT_CMD=lake build
# OBR_ACCEPTANCE_STRICT=
# OBR_USE_REAL_FRESH_CHECKER=
# OBR_FRESH_CHECK_CMD=lean4checker --fresh

# --- Worker isolation ---
# OBR_WORKER_RUNNER=
# OBR_DOCKER_IMAGE=lean-worker:latest
# OBR_CONTAINER_NETWORK=none
# OBR_INTERACTIVE_RUNNER_MAX=
# OBR_BATCH_RUNNER_MAX=

# --- Policy / CORS / env ---
# OBR_POLICY_PACK=strict_patch_gate_v1
# OBR_CORS_ORIGINS=http://localhost:3000
# OBR_ENV=

# --- Logging / metrics / coordination ---
# OBR_LOG_LEVEL=INFO
# OBR_METRICS_ENABLED=
# OBR_REDIS_URL=

# --- Optional: LangSmith (telemetry); do not commit real keys ---
# LANGCHAIN_API_KEY=

# --- Optional: OTLP (telemetry) ---
# OBR_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Orchestrator (resume service); set on Gateway when using HTTP resume ---
# OBR_ORCHESTRATOR_URL=http://localhost:8001

# --- MCP server (uses OBR_GATEWAY_URL above; OBLIGATION_GATEWAY_URL supported for backward compat) ---
