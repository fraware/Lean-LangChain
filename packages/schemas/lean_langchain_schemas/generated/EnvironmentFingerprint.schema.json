{
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "repo_id": {
      "title": "Repo Id",
      "type": "string"
    },
    "repo_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Repo Url"
    },
    "commit_sha": {
      "title": "Commit Sha",
      "type": "string"
    },
    "lean_toolchain": {
      "title": "Lean Toolchain",
      "type": "string"
    },
    "lakefile_hash": {
      "title": "Lakefile Hash",
      "type": "string"
    },
    "manifest_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Manifest Hash"
    },
    "target_platform": {
      "default": "linux/amd64",
      "title": "Target Platform",
      "type": "string"
    },
    "build_flags": {
      "items": {
        "type": "string"
      },
      "title": "Build Flags",
      "type": "array"
    },
    "os_family": {
      "default": "linux",
      "enum": [
        "linux",
        "darwin",
        "windows"
      ],
      "title": "Os Family",
      "type": "string"
    },
    "imported_packages": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Imported Packages"
    }
  },
  "required": [
    "repo_id",
    "commit_sha",
    "lean_toolchain",
    "lakefile_hash"
  ],
  "title": "EnvironmentFingerprint",
  "type": "object"
}