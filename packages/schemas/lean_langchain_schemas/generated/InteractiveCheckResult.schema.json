{
  "$defs": {
    "Diagnostic": {
      "additionalProperties": false,
      "properties": {
        "severity": {
          "enum": [
            "error",
            "warning",
            "information",
            "hint"
          ],
          "title": "Severity",
          "type": "string"
        },
        "file": {
          "title": "File",
          "type": "string"
        },
        "line": {
          "title": "Line",
          "type": "integer"
        },
        "column": {
          "title": "Column",
          "type": "integer"
        },
        "end_line": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Line"
        },
        "end_column": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Column"
        },
        "code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "source": {
          "default": "lean",
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "severity",
        "file",
        "line",
        "column",
        "message"
      ],
      "title": "Diagnostic",
      "type": "object"
    },
    "GoalSnapshot": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "plainGoal",
            "plainTermGoal"
          ],
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File"
        },
        "line": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Line"
        },
        "column": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column"
        }
      },
      "required": [
        "kind",
        "text"
      ],
      "title": "GoalSnapshot",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "ok": {
      "title": "Ok",
      "type": "boolean"
    },
    "phase": {
      "default": "interactive",
      "title": "Phase",
      "type": "string"
    },
    "diagnostics": {
      "items": {
        "$ref": "#/$defs/Diagnostic"
      },
      "title": "Diagnostics",
      "type": "array"
    },
    "goals": {
      "items": {
        "$ref": "#/$defs/GoalSnapshot"
      },
      "title": "Goals",
      "type": "array"
    },
    "stdout": {
      "default": "",
      "title": "Stdout",
      "type": "string"
    },
    "stderr": {
      "default": "",
      "title": "Stderr",
      "type": "string"
    },
    "timing_ms": {
      "default": 0,
      "title": "Timing Ms",
      "type": "integer"
    }
  },
  "required": [
    "ok"
  ],
  "title": "InteractiveCheckResult",
  "type": "object"
}